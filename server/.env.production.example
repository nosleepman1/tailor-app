# ============================================
# Application Configuration
# ============================================
APP_NAME="Tailor"
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APP_URL=https://api.yourdomain.com

# ============================================
# Database Configuration
# ============================================
DB_CONNECTION=pgsql
DB_HOST=your-postgres-host.railway.app
DB_PORT=5432
DB_DATABASE=tailor_production
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password
DB_SSLMODE=require

# ============================================
# Cache Configuration
# ============================================
CACHE_DRIVER=redis
CACHE_PREFIX=tailor_cache_

# ============================================
# Session Configuration
# ============================================
SESSION_DRIVER=cookie
SESSION_DOMAIN=.yourdomain.com
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,api.yourdomain.com

# ============================================
# Authentication
# ============================================
AUTH_GUARD=sanctum

# ============================================
# Mail Configuration
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_username
MAIL_PASSWORD=your_password
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME="Tailor App"
MAIL_FROM_ADDRESS=noreply@yourdomain.com

# ============================================
# API Configuration
# ============================================
API_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=your-redis-host
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ============================================
# Queue Configuration
# ============================================
QUEUE_CONNECTION=sync
# Use 'database' or 'redis' for background jobs
# QUEUE_CONNECTION=database

# ============================================
# File Storage Configuration
# ============================================
FILESYSTEM_DISK=local
# For AWS S3 storage:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=xxxxx
# AWS_SECRET_ACCESS_KEY=xxxxx
# AWS_DEFAULT_REGION=eu-west-1
# AWS_BUCKET=tailor-prod-bucket

# ============================================
# Logging Configuration
# ============================================
LOG_CHANNEL=stack
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

# ============================================
# CORS Configuration
# ============================================
CORS_PATHS="api/*,sanctum/csrf-cookie"
CORS_ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"
CORS_ALLOWED_METHODS="*"
CORS_ALLOWED_HEADERS="*"
CORS_EXPOSED_HEADERS="*"
CORS_MAX_AGE=86400

# ============================================
# Broadcasting (Optional)
# ============================================
BROADCAST_DRIVER=log
# For Pusher:
# BROADCAST_DRIVER=pusher
# PUSHER_APP_ID=xxxxx
# PUSHER_APP_KEY=xxxxx
# PUSHER_APP_SECRET=xxxxx
# PUSHER_HOST=api-eu.pusher.com
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# PUSHER_APP_CLUSTER=eu

# ============================================
# Third-party Services
# ============================================

# Sentry Error Tracking
# SENTRY_LARAVEL_DSN=https://xxxxx@sentry.io/xxxxx
# SENTRY_ENVIRONMENT=production

# AWS SES (if using for emails)
# AWS_SES_ACCESS_KEY_ID=xxxxx
# AWS_SES_SECRET_ACCESS_KEY=xxxxx
# AWS_SES_REGION=eu-west-1

# Payment Gateway (if applicable)
# STRIPE_PUBLIC_KEY=pk_live_xxxxx
# STRIPE_SECRET_KEY=sk_live_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ============================================
# Security Headers
# ============================================
SECURE_HSTS_MAX_AGE=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# ============================================
# Performance
# ============================================
# Cache query results
APP_CACHE_ROUTES=true
APP_CACHE_CONFIG=true
APP_CACHE_VIEWS=true
APP_CACHE_EVENTS=true

# ============================================
# Developer Tools (Disable in Production!)
# ============================================
TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false
QUERY_DETECTOR_ENABLED=false
